# Per-GPU containers regime patched vLLM image for elastic scaling.
#
# Layers on top of xtrans-vllm-ep:v0.19.0 (= vllm/vllm-openai:v0.19.0 +
# ray[default]==2.55.0, built from Dockerfile.base) and applies every
# .patch in ./patches/ to the vLLM install inside the image. The patches
# are local research workarounds for vLLM 0.19.0's per-GPU container
# scaling bugs; see analysis_report.html for mechanism detail and
# patches/*.patch for per-patch commentary.
#
# Resulting image is tagged xtrans-vllm-ep-patched:v0.19.0 by the
# ensure_patched_image helper in common.py (auto-built by
# 3_per_gpu_containers.py on first use).

FROM xtrans-vllm-ep:v0.19.0

WORKDIR /usr/local/lib/python3.12/dist-packages

COPY patches/ /tmp/exp-a3-patches/

# Apply each patch in numeric order. Fail-fast if any patch fails to
# apply -- silent skips produce confusing runtime failures later.
RUN set -eu; \
    patches=$(find /tmp/exp-a3-patches -maxdepth 1 -name '*.patch' 2>/dev/null | sort); \
    if [ -z "$patches" ]; then \
        echo "No patches to apply -- image will be identical to base."; \
    else \
        for p in $patches; do \
            echo "=== Applying $p ==="; \
            patch -p1 < "$p"; \
        done; \
        echo "All patches applied."; \
    fi

# Quick sanity-check the vLLM install still imports after patching.
RUN python3 -c "import vllm; print('vllm', vllm.__version__, 'imports OK')"
