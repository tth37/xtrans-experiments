# exp_a3 patch 0001: EPLB scale-down precondition check
#
# Against: vllm 0.19.0
# Target file: vllm/distributed/eplb/eplb_state.py
# Applied by: Dockerfile.phase3 (produces xtrans-vllm-ep-patched:v0.19.0)
#
# Problem: on scale-down with num_redundant_experts=0, the formula
#   num_replicas = num_replicas // ep_group.size() * num_gpus
# halves total physical experts below num_logical (e.g. DP=4 -> 2 with 128
# logical: 128 // 4 * 2 = 64 < 128). The downstream replicate_experts asserts
# num_redundant = num_phy - num_log >= 0 and crashes inside a Ray worker,
# taking the whole serving process down with a cryptic AssertionError.
#
# Fix: detect the precondition violation before entering the broken code
# path and raise ValueError with a message that names the exact CLI flag
# the operator needs to set. The serving process still dies (proper
# rejection at the HTTP layer would require reaching into the elastic_ep
# API handler on engine core before dispatching to workers -- out of scope
# for this narrow patch), but the failure mode is now diagnosable.
#
# Known limitation: this does NOT make scale-down work for
# num_redundant_experts=0 from a cold-DP=N start. A proper fix requires
# letting per-GPU physical-expert density grow on scale-down, which
# cascades into _map_{new,old}_expert_indices_with_rank_mapping (assume
# constant num_local_physical_experts), per-GPU expert_weights allocations
# (sized for the pre-scale density), physical_to_logical_map shape, and
# expert_load_window indexing. That's a multi-file structural change
# outside this experiment's scope; see analysis_report.html for the
# mechanism section and the Conclusions for the deferred follow-up.
#
# Note: Phase 3's primary 2 -> 4 -> 2 cycle does NOT need this patch on
# the critical path (scale-up builds redundancy that scale-down consumes).
# This patch matters only for cold-DP=N starts that attempt scale-down
# before scale-up; it converts a cryptic assertion into an actionable
# ValueError pointing operators at --eplb-config.num_redundant_experts.
--- a/vllm/distributed/eplb/eplb_state.py
+++ b/vllm/distributed/eplb/eplb_state.py
@@ -699,9 +699,26 @@
             tcp_store_group = coordinator.tcp_store_group
             num_nodes = _node_count_with_rank_mapping(tcp_store_group, rank_mapping)
             num_gpus = sum(new_rank != -1 for new_rank in rank_mapping.values())
-            num_replicas = (
-                num_replicas // ep_group.size() * num_gpus
-            )  # handle num replicas change
+            new_num_replicas = num_replicas // ep_group.size() * num_gpus
+            if new_num_replicas < model.num_logical_experts:
+                # Proportional shrink would drop total physical experts below
+                # num_logical, violating num_phy >= num_log in replicate_experts.
+                # TODO: the tight per-pair minimum is
+                # num_logical_experts * (ep_group.size() - num_gpus) // num_gpus
+                # (plus divisibility adjustment). The message below suggests
+                # num_logical_experts as a conservative upper bound that works
+                # for any supported scale-down ratio.
+                current_redundant = (
+                    model.num_physical_experts - model.num_logical_experts
+                )
+                raise ValueError(
+                    f"Scale-down from ep_size={ep_group.size()} to {num_gpus} "
+                    f"requires num_redundant_experts >= {model.num_logical_experts} "
+                    f"(current: {current_redundant}). Pass "
+                    f"--eplb-config.num_redundant_experts={model.num_logical_experts} "
+                    f"at vllm serve startup."
+                )
+            num_replicas = new_num_replicas
         else:
             num_nodes = get_node_count()
             num_gpus = ep_group.size()
